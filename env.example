# GrantPubTracker environment configuration
# Copy this file to .env and update the values for your local machine.

# NCBI requires an email address when using the Entrez API.
ENTREZ_EMAIL=your_email@example.com

# Optional pause between NCBI requests, in seconds.
NCBI_DELAY_SECONDS=0.5

# Step 2: Author-affiliation extraction
AFFILIATION_INPUT_CSV=data/pubmed_results_grouped_with_mesh.csv
AFFILIATION_OUTPUT_CSV=output/pubmed_author_affiliations.csv

# Step 3: Citation formatting
CITATION_INPUT_CSV=data/pubmed_results_verified_affiliations.csv
CITATION_OUTPUT_CSV=output/formatted_citations_with_pmcid.csv
